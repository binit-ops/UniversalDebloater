<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/app_bg">

    <!-- Top Panel: Search and Filters -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true">
        
        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search apps..."
            android:textColorHint="#99FFFFFF"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:background="@drawable/glass_bg"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">
            
            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="ALL"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp"/>
                
            <Button
                android:id="@+id/btnFilterSystem"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="SYSTEM"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp"/>
                
            <Button
                android:id="@+id/btnFilterUser"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="USER"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="@drawable/glass_bg"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            
            <Button
                android:id="@+id/btnLoadProfile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Load"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Save"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>
                
            <Button
                android:id="@+id/btnBackup"
                android:layout_width="0dp"
                android:layout_weight="1.5"
                android:layout_height="40dp"
                android:text="BACKUP APK"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#FFC107"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnRestore"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="RESTORE"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#4CAF50"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnFreeze"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="FREEZE"
                android:textSize="12sp"
                android:background="@drawable/btn_squircle"
                android:textColor="#2196F3"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnNuke"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="NUKE"
                android:textSize="12sp"
                android:background="@drawable/btn_nuke_squircle"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topPanel"
        android:layout_above="@id/bottomBar"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"/>

</RelativeLayout>
